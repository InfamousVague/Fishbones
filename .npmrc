# `react-native-web@0.19.13` declares a `react@^18.0.0` peer
# dependency but works fine on react 19 in practice — Monaco, the
# Solidity tooling, and our own React 19 code all need 19, and
# downgrading the whole tree just for the RN preview iframe isn't
# worth it.
#
# `legacy-peer-deps=true` makes `npm install` and `npm ci` ignore
# the conflict the same way our local installs already do. Without
# this, CI's npm ci fails with ERESOLVE before the Vite build can
# even start. Same posture the official react-native-web docs
# recommend until the 0.20.x release lands with React 19 peer.
legacy-peer-deps=true
